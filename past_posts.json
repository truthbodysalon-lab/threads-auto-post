    "replies_count": 0
  },
  {
    "id": "17885736444581179",
    "text": "本田圭佑の解説面白すぎだし\nめっちゃ的確！",
    "timestamp": "2026-06-14T21:48:02+0000",
    "like_count": 2,
    "views": 1337,
    "replies_count": 0
  },
  {
    "id": "17933403807297638",
    "text": "やば！！！",
