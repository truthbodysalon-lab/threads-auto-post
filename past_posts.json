    "views": 403,
    "replies_count": 0
  },
  {
    "id": "18106620136796990",
    "text": "キターーー！！\n中村！！！",
    "timestamp": "2026-06-14T21:16:14+0000",
    "like_count": 0,
    "views": 43,
    "replies_count": 0
  },
  {
